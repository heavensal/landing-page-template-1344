---
import { getFixedT, isMultilangEnabled, type Locale } from '../i18n/i18n';
import { siteConfig } from '../site.config';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
	locale: Locale;
	primaryHref?: string;
	secondaryHref?: string;
}

const { locale, primaryHref = '#contact', secondaryHref } = Astro.props;
const t = getFixedT(locale);
const showLanguageSwitcher = isMultilangEnabled();
---

<section
	class="relative min-h-[85vh] w-full flex flex-col justify-center px-4 py-24 bg-linear-to-br from-emerald-950 via-gray-900 to-gray-950 text-white"
	aria-label={t('HeroSection.ariaLabel')}
>
	{showLanguageSwitcher && <LanguageSwitcher locale={locale} />}
	<div class="relative z-10 container mx-auto max-w-3xl text-center">
		<p class="mb-4 text-sm uppercase tracking-widest text-emerald-400">
			{t('HeroSection.eyebrow')}
		</p>
		<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-4">
			{siteConfig.name}
		</h1>
		<p class="text-lg md:text-xl text-white/90 mb-10 max-w-2xl mx-auto">
			{t('HeroSection.tagline')}
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a
				href={primaryHref}
				class="inline-flex items-center justify-center px-8 py-4 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900"
			>
				{t('HeroSection.primaryCta')}
			</a>
			{
				secondaryHref && (
					<a
						href={secondaryHref}
						class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/80 text-white font-semibold rounded-lg hover:bg-white hover:text-gray-900 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-gray-900"
					>
						{t('HeroSection.secondaryCta')}
					</a>
				)
			}
		</div>
	</div>
</section>
